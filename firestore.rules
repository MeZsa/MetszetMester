rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "Mekli.Zsuzsanna@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidCourse(data) {
      return data.id is string && data.id.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.description is string;
    }

    function isValidModule(data) {
      return data.id is string && data.id.size() > 0 &&
             data.courseId is string && data.courseId.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.order is number;
    }

    function isValidLesson(data) {
      return data.id is string && data.id.size() > 0 &&
             data.moduleId is string && data.moduleId.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.content is string &&
             data.order is number &&
             (!('images' in data) || data.images is list) &&
             (!('microscopeImage' in data) || data.microscopeImage is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId && 
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCourse(request.resource.data);

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin() && isValidModule(request.resource.data);

        match /lessons/{lessonId} {
          allow read: if true;
          allow write: if isAdmin() && isValidLesson(request.resource.data);
        }
      }
    }
  }
}
