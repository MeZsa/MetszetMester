{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "A histology course containing modules.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "description"]
    },
    "Module": {
      "title": "Module",
      "description": "A module within a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "courseId", "title", "order"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A lesson within a module.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "microscopeImage": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "moduleId", "title", "content", "order"]
    }
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "The collection of histology courses."
    },
    "/courses/{courseId}/modules/{moduleId}": {
      "schema": "Module",
      "description": "The collection of modules for a course."
    },
    "/courses/{courseId}/modules/{moduleId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "The collection of lessons for a module."
    }
  }
}
